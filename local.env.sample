# ============================================================
# FinAi — Environment Variables Sample
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/finai

# ── Authentication ────────────────────────────────────────────
# Long random secret for signing JWT tokens
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-secret-string

# ── AI / LLM Providers ───────────────────────────────────────
# Fin (FinAi's AI) auto-routes across all providers below.
# Priority order: Grok → OpenAI → Groq → DeepSeek → Google →
#                 GitHub → OpenRouter → NVIDIA → Local fallback
# Only keys that are set will be used — add as many as you have.
# The first available key in priority order wins each request.

# 1. Grok (xAI) — console.x.ai  [PRIORITY 1]
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. OpenAI (ChatGPT) — platform.openai.com  [PRIORITY 2]
#    Also used for ChromaDB RAG embeddings
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 3. Groq Cloud — console.groq.com  [PRIORITY 3]
#    Ultra-fast inference — llama-3.3-70b-versatile
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. DeepSeek — platform.deepseek.com  [PRIORITY 4]
#    deepseek-chat model
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 5. Google AI Studio (Gemini) — aistudio.google.com  [PRIORITY 5]
#    gemini-2.0-flash model
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# 6. GitHub Models — github.com/marketplace/models  [PRIORITY 6]
#    Uses your GitHub personal access token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# 7. OpenRouter — openrouter.ai  [PRIORITY 7]
#    Free tier available — meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# 8. NVIDIA Build — build.nvidia.com  [PRIORITY 8]
#    meta/llama-3.1-8b-instruct
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# Note: If NO keys are set, Fin falls back to the built-in
# Local Intelligence Engine (rule-based, no cloud calls needed).

# ── Market Data ──────────────────────────────────────────────
# NewsAPI.org — free tier at newsapi.org (used for FinEventAI)
NEWSAPI_KEY=your_newsapi_key_here

# AlphaVantage — free at alphavantage.co
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── Celery / Redis (optional) ─────────────────────────────────
# If not set, app runs in eager (synchronous) mode — no Redis needed
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=true

# ── Trading Brokers (optional) ───────────────────────────────
# Alpaca Paper Trading — app.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance API — binance.com
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# ── Notifications (optional) ─────────────────────────────────
# Telegram bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Twilio — for WhatsApp alerts (twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Slack — slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#trading-alerts

# ── Email (optional) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# ── App ──────────────────────────────────────────────────────
# Set to "production" for deployment
APP_ENV=development
