# ============================================================
# FinAi — Environment Variables Sample
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/finai

# ── Authentication ────────────────────────────────────────────
# Long random secret for signing JWT tokens
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-secret-string

# ── AI / LLM ─────────────────────────────────────────────────
# PRIMARY: Grok (xAI) — get key at console.x.ai
# Used for: ChatFin assistant, AI signals, market analysis
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# FALLBACK: OpenAI — get key at platform.openai.com
# Used for: embeddings (ChromaDB RAG), fallback chat if Grok fails
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Anthropic Claude — get key at console.anthropic.com
# Uncomment to enable as a secondary fallback
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Google Gemini — get key at aistudio.google.com
# Uncomment to enable Gemini as another fallback option
# GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# LLM routing priority: grok → openai → anthropic → gemini
# First available key with a valid response is used
LLM_MODEL=grok-3-mini
LLM_FALLBACK_MODEL=gpt-4o-mini

# ── Market Data ──────────────────────────────────────────────
# NewsAPI.org — free tier at newsapi.org (used for FinEventAI)
NEWSAPI_KEY=your_newsapi_key_here

# AlphaVantage — free at alphavantage.co
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── Celery / Redis (optional) ─────────────────────────────────
# If not set, app runs in eager (synchronous) mode — no Redis needed
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1

# ── Trading Brokers (optional) ───────────────────────────────
# Alpaca Paper Trading — app.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance API — binance.com
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# ── Notifications (optional) ─────────────────────────────────
# Telegram bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Twilio — for WhatsApp alerts (twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Slack — slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#trading-alerts

# ── Email (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
